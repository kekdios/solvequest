{
  "name": "solvequest",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "tsc -b && tsc -p tsconfig.node.json && vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "preview": "vite preview",
    "test": "tsc -b && tsc -p tsconfig.node.json && npm run test:hl",
    "test:hl": "node scripts/test-hl-feeds.mjs",
    "db:init": "node scripts/init-db.mjs",
    "db:migrate": "node scripts/migrate-all.mjs",
    "db:provision": "tsx scripts/provision-account.ts",
    "prize:record-winner": "tsx scripts/record-daily-prize-winner.ts",
    "prize:award": "tsx scripts/run-daily-prize-award.ts",
    "test:swap-preflight": "tsx scripts/test-swap-treasury-preflight.ts",
    "treasury:gen": "tsx scripts/generate-treasury-keypair.ts",
    "treasury:b64-to-wallet": "tsx scripts/treasury-b64-to-wallet.ts"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-phantom": "^0.9.29",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-solflare": "^0.6.33",
    "@solana/web3.js": "^1.98.4",
    "better-sqlite3": "^11.10.0",
    "bs58": "^6.0.0",
    "buffer": "^6.0.3",
    "dotenv": "^16.4.7",
    "ed25519-hd-key": "^1.3.0",
    "express": "^4.21.2",
    "geoip-lite": "^1.4.10",
    "http-proxy-middleware": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-qr-code": "^2.0.18",
    "resend": "^6.10.0",
    "tsx": "^4.19.3",
    "tweetnacl": "^1.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "typescript": "~5.7.2",
    "vite": "^6.0.3"
  }
}
