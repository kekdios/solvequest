{
  "name": "solvequest",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "tsc -b && tsc -p tsconfig.node.json && vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "preview": "vite preview",
    "test": "tsc -b && tsc -p tsconfig.node.json && npm run test:hl",
    "test:hl": "node scripts/test-hl-feeds.mjs",
    "db:init": "node scripts/init-db.mjs",
    "db:migrate:receive": "node scripts/migrate-receive-addresses.mjs",
    "db:migrate:email": "node scripts/migrate-add-email-to-accounts.mjs",
    "db:migrate:tier": "node scripts/migrate-tier-column.mjs",
    "db:migrate:account-sync": "node scripts/migrate-account-sync-state.mjs",
    "db:migrate:deposit-worker": "node scripts/migrate-deposit-worker.mjs",
    "db:migrate:vault-interest": "node scripts/migrate-vault-interest.mjs",
    "db:provision": "node scripts/provision-account.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "http-proxy-middleware": "^3.0.3",
    "tsx": "^4.19.3",
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-phantom": "^0.9.29",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-solflare": "^0.6.33",
    "@solana/web3.js": "^1.98.4",
    "buffer": "^6.0.3",
    "jsonwebtoken": "^9.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-qr-code": "^2.0.18",
    "resend": "^6.10.0",
    "tweetnacl": "^1.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "typescript": "~5.7.2",
    "vite": "^6.0.3"
  }
}
