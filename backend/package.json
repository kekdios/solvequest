{
  "name": "solvequest-backend",
  "version": "0.1.10",
  "description": "SolveQuest arena API (Express). Batch validation has no API keys; limits are env-driven.",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "test": "node --import ./test/setup-env.mjs --test test/*.test.js",
    "test:vault-puzzle": "node --import ./test/vault-sqlite-prelude.mjs --test test/vault-puzzle-load.node-test.js",
    "vault-init": "node ../scripts/vault-init.mjs"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "better-sqlite3": "^11.10.0",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "ed25519-hd-key": "^1.3.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "lru-cache": "^11.2.7",
    "redis": "^5.11.0",
    "tweetnacl": "^1.0.3"
  }
}
