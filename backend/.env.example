# Required — no mnemonic in repo; win = derived Solana address matches TARGET_ADDRESS.
# SOLUTION_HASH is public commitment only (SHA-256 of normalized mnemonic); not used to validate wins.

TARGET_ADDRESS=6h4oTiusvVchVP67bjTLmuCxGjyPo2fSNTR1Pq4nwwGy
SOLUTION_HASH=51c2a6fd1a8541e22e77de993206a240a75356286427f53ae2a31ef38a30beca

# Comma-separated 12 words (order is not the solution; server shuffles for display).
PUZZLE_WORDS=estate,refuse,glad,rare,only,faith,maximum,wide,army,hub,rent,wisdom

# Optional puzzle id
# PUZZLE_ID=001

# Round (timed arena) — Redis sets NX on first boot; in-memory sets on process start
# ROUND_ID=alpha-1
# ROUND_START_DELAY_SEC=0
# ROUND_DURATION_SEC=86400
# ROUND_SETTLE_GRACE_SEC=3
# ROUND_ARCHIVE_DELAY_SEC=120
# AUTO_ROTATE_ROUNDS=0
# ROUND_ROTATION_JSON=[]

# Override difficulty label: easy | medium | hard (else derived from constraints)
# PUZZLE_DIFFICULTY=medium

# Require solve:<round_id>:<puzzle_id>:<ts>:<nonce>:<hash> for claims
# CLAIM_REQUIRE_ROUND_IN_MESSAGE=0

# Leaderboard: subtract this from ZSET score on constraint reject (e.g. -0.5)
# LEADERBOARD_CONSTRAINT_PENALTY=0
# Max score increments per wallet per second (anti-spam)
# LEADERBOARD_MAX_INCR_PER_SEC=20

# Optional difficulty: fixed words at indices (0-based). JSON object.
# Reject before BIP39 if any position does not match.
PUZZLE_CONSTRAINTS_JSON={"fixed_positions":{"0":"estate","11":"wisdom"}}

# Redis (omit for single-process in-memory dev — not safe for multi-instance)
# REDIS_URL=redis://127.0.0.1:6379

# Prize balance RPC reads
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Prize wallet SPL balance (default SAUSD mint if unset)
# PRIZE_SPL_MINT=CK9PodBifHymLBGeZujExFnpoLCsYxAw7t8c8LsDKLxG
# Legacy alias: USDC_MINT=
# PRIZE_BALANCE_TTL_MS=10000

# Batch validation (no API keys)
# VALIDATE_BATCH_MAX=1000
# PAID_TIER_BATCH_MAX=1000
# VALIDATE_BATCH_CONCURRENCY=32
# PAID_TIER_BATCH_CONCURRENCY=32
# RATE_LIMIT_VALIDATE_BATCH_MAX=20

# Claim (signed win lane)
# RATE_LIMIT_CLAIM_MAX=60
# CLAIM_SIGNATURE_WINDOW_SEC=30
# CLAIM_LOCK_TTL_SEC=5
# ALLOW_LEGACY_SOLVE_MESSAGE=0
# CLAIM_REQUIRE_MNEMONIC_BINDING=0
# Set to 1 in production: only accept solve:{id}:{ts}:{nonce}:{mnemonic_sha256_hex}
# DERIVATION_CACHE_MAX=5000

# Admin: payout job updates + wizard “clear solved” (send as x-admin-key)
# ADMIN_CONTROL_KEY=change-me

# Enable puzzle-wizard.html derive API in production (mnemonic in HTTP body — use HTTPS)
# ALLOW_WIZARD_DERIVE=1
# (also accepts: true, yes, on — restart server after change)
# WIZARD_DERIVE_MAX_PER_MIN=40
# WIZARD_CLEAR_SOLVED_MAX_PER_MIN=20

# Payout job pipeline (audited job creation on settle)
# PAYOUT_AMOUNT_USDC=0
# PAYOUT_MAX_RETRIES=5

