{
  "openapi": "3.0.3",
  "info": {
    "title": "SolveQuest Arena API",
    "description": "HTTP API for the SolveQuest competitive puzzle arena. Player agents use these endpoints on the same origin as the arena UI. There is no API key or credit system: batch limits and rate caps are configured by the operator via environment variables. Operator-only routes use the x-admin-key header (ADMIN_CONTROL_KEY).",
    "version": "1.0.0"
  },
  "servers": [{ "url": "/", "description": "Same host as the arena (set explicitly in clients if needed)." }],
  "paths": {
    "/health": {
      "get": {
        "summary": "Liveness probe",
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "object" } } } } }
      }
    },
    "/version": {
      "get": {
        "summary": "App version string",
        "responses": {
          "200": {
            "description": "Semantic version from backend/package.json",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "version": { "type": "string" } },
                  "required": ["version"]
                }
              }
            }
          }
        }
      }
    },
    "/puzzle": {
      "get": {
        "summary": "Current puzzle and commitments",
        "description": "Includes vault_empty (boolean): when true, PUZZLE_SOURCE=sqlite but there is no unsolved row in the vault and the server is serving TARGET_ADDRESS / PUZZLE_WORDS from env until bootstrap + restart. words are shuffled for display; evaluation uses canonical order.",
        "responses": {
          "200": {
            "description": "Puzzle JSON",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string", "description": "Puzzle public id" },
                    "difficulty": { "type": ["string", "null"] },
                    "words": { "type": "array", "items": { "type": "string" }, "description": "Shuffled display order" },
                    "solved": { "type": "boolean" },
                    "vault_empty": {
                      "type": "boolean",
                      "description": "True if sqlite vault has no unsolved row (env fallback active)."
                    },
                    "solution_hash": { "type": "string" },
                    "target_address": { "type": "string" },
                    "constraints": { "type": "object", "description": "Puzzle constraints object (may be empty)" },
                    "winner": { "type": ["string", "null"], "description": "Wallet id from winning POST /submit when solved" }
                  },
                  "required": ["id", "words", "solved", "vault_empty", "solution_hash", "target_address", "constraints"]
                }
              }
            }
          }
        }
      }
    },
    "/puzzle/recent": {
      "get": {
        "summary": "Recent puzzle rows from SQLite vault",
        "description": "Returns { source: \"env\", puzzles: [] } when PUZZLE_SOURCE is not sqlite. Otherwise { source: \"sqlite\", puzzles: [...] } with safe fields (no word list or ciphertext). Optional query limit (default 10, max 50).",
        "parameters": [{ "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 50, "default": 10 } }],
        "responses": {
          "200": {
            "description": "source + puzzles array (id, public_id, status, difficulty, winner_id, solved_at, created_at, target_address)"
          }
        }
      }
    },
    "/stats": {
      "get": {
        "summary": "Arena statistics",
        "responses": { "200": { "description": "Stats JSON" } }
      }
    },
    "/prize/balances": {
      "get": {
        "summary": "Prize wallet SPL + SOL balances (RPC)",
        "description": "Reads TARGET_ADDRESS. SPL mint: PRIZE_SPL_MINT, else QUEST_MINT, else USDC_MINT, else default SAUSD mint. Returns prize_token_balance, prize_token_mint, sol_balance, address (see server.js). Not a USD price — on-chain ui amounts.",
        "responses": { "200": { "description": "Balances JSON" } }
      }
    },
    "/payout/jobs": {
      "get": {
        "summary": "List recent payout jobs (audited USDC pipeline)",
        "parameters": [{ "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } }],
        "responses": { "200": { "description": "{ jobs: [...] }" } }
      }
    },
    "/payout/jobs/{jobId}/attempt": {
      "post": {
        "summary": "Admin: record payout attempt (tx_sig or error)",
        "parameters": [
          { "name": "jobId", "in": "path", "required": true, "schema": { "type": "string" } },
          {
            "name": "x-admin-key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" },
            "description": "Must match ADMIN_CONTROL_KEY"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "tx_sig": { "type": "string" },
                  "error": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated job object" },
          "404": { "description": "job_not_found" }
        }
      }
    },
    "/validate": {
      "post": {
        "summary": "Single mnemonic evaluation",
        "responses": { "200": { "description": "Validation result object" } }
      }
    },
    "/validate_batch": {
      "post": {
        "summary": "Batch mnemonic evaluation (no authentication)",
        "description": "Max array length and internal concurrency are set server-side (VALIDATE_BATCH_MAX, VALIDATE_BATCH_CONCURRENCY; see GET /public/developer-info).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["mnemonics"],
                "properties": {
                  "mnemonics": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Array of per-mnemonic validation results" } }
      }
    },
    "/submit": {
      "post": {
        "summary": "Submit candidate phrase; records win or validation outcome",
        "description": "Body must include phrase or mnemonic (12 words). wallet defaults to anonymous and is stored as the winner id on win.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "phrase": { "type": "string" },
                  "mnemonic": { "type": "string", "description": "Alias for phrase" },
                  "wallet": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "status: win | already_solved | invalid | valid_but_wrong | constraint_violation; winner when applicable"
          },
          "500": { "description": "internal_error" }
        }
      }
    },
    "/events": {
      "get": {
        "summary": "Server-Sent Events stream",
        "description": "Initial hello, then events with type among hello, submit, win, puzzle_cleared, new_puzzle, payout_job, etc.",
        "responses": {
          "200": {
            "description": "text/event-stream",
            "content": { "text/event-stream": { "schema": { "type": "string" } } }
          }
        }
      }
    },
    "/public/developer-info": {
      "get": {
        "summary": "Developer page metadata (batch limits, rate caps, wizard flag)",
        "responses": {
          "200": {
            "description": "Public tuning knobs for agents and static pages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "validate_batch_max": { "type": "integer", "description": "Max mnemonics per validate_batch request" },
                    "rate_limit_validate_batch_per_sec": {
                      "type": "number",
                      "description": "Approximate per-IP req/s cap for validate_batch"
                    },
                    "wizard_derive_enabled": {
                      "type": "boolean",
                      "description": "Whether POST /public/wizard-derive is enabled"
                    }
                  },
                  "required": ["validate_batch_max", "rate_limit_validate_batch_per_sec", "wizard_derive_enabled"]
                }
              }
            }
          }
        }
      }
    },
    "/public/wizard-derive": {
      "post": {
        "summary": "Operator: derive puzzle .env fields from mnemonic (production: ALLOW_WIZARD_DERIVE)",
        "responses": {
          "200": { "description": "Derivation JSON" },
          "404": { "description": "wizard_derive_disabled" }
        }
      }
    },
    "/public/admin/new-puzzle-draft": {
      "post": {
        "summary": "Admin: generate random puzzle draft (mnemonic + derived fields); sqlite vault only",
        "parameters": [
          {
            "name": "x-admin-key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" },
            "description": "Must match ADMIN_CONTROL_KEY"
          }
        ],
        "responses": {
          "200": { "description": "{ ok, draft: { mnemonic, public_id, target_address, ... } }" },
          "401": { "description": "unauthorized" },
          "400": { "description": "vault_only" }
        }
      }
    },
    "/public/admin/new-puzzle": {
      "post": {
        "summary": "Admin: retire unsolved rows, insert new puzzle, reload; sqlite vault only",
        "parameters": [
          {
            "name": "x-admin-key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" },
            "description": "Must match ADMIN_CONTROL_KEY"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "public_id, target_address, solution_hash, puzzle_words (csv or array), optional constraints_json, difficulty"
              }
            }
          }
        },
        "responses": {
          "200": { "description": "{ ok, puzzle_id, row_id, quest_fund_tx, quest_fund_error }" },
          "400": { "description": "vault_only or validation_error" },
          "409": { "description": "public_id_conflict" },
          "401": { "description": "unauthorized" }
        }
      }
    },
    "/public/wizard-clear-solved": {
      "post": {
        "summary": "Admin: clear puzzle winner in Redis/memory (x-admin-key)",
        "parameters": [
          {
            "name": "x-admin-key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" },
            "description": "Must match ADMIN_CONTROL_KEY"
          }
        ],
        "responses": {
          "200": { "description": "{ ok: true }" },
          "401": { "description": "unauthorized" },
          "503": { "description": "admin_control_not_configured" }
        }
      }
    },
    "/public/admin/visitor-log": {
      "get": {
        "summary": "Admin: paginated visitor page-view log (IP + geoip-lite)",
        "parameters": [
          {
            "name": "x-admin-key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" },
            "description": "Must match ADMIN_CONTROL_KEY"
          },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 100 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": {
          "200": { "description": "{ ok, visitors: [...], total }" },
          "401": { "description": "unauthorized" },
          "503": { "description": "admin_control_not_configured" }
        }
      }
    }
  }
}
